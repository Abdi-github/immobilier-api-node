{
  "info": {
    "_postman_id": "amenity-module-collection",
    "name": "Immobilier API - Amenity Module",
    "description": "API endpoints for managing property amenities in the Immobilier platform.\n\nAmenities define features and characteristics of properties (parking, balcony, security, etc.).\n\n## Features\n- Multi-language support (EN, FR, DE, IT)\n- Group-based organization (parking, outdoor, security, kitchen, etc.)\n- Admin CRUD operations\n- Search and filtering capabilities",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Public Endpoints",
      "description": "Public endpoints for retrieving amenity information",
      "item": [
        {
          "name": "Get All Amenities",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept-Language",
                "value": "{{lang}}",
                "description": "Language preference (en, fr, de, it)"
              }
            ],
            "url": {
              "raw": "{{base_url}}/public/amenities?page={{page}}&limit={{limit}}&group={{group}}&search={{search}}&is_active={{is_active}}&sort={{sort}}&lang={{lang}}",
              "host": ["{{base_url}}"],
              "path": ["public", "amenities"],
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}",
                  "description": "Page number (default: 1)"
                },
                {
                  "key": "limit",
                  "value": "{{limit}}",
                  "description": "Items per page (default: 50, max: 100)"
                },
                {
                  "key": "group",
                  "value": "{{group}}",
                  "description": "Filter by group: general, kitchen, bathroom, outdoor, security, parking, accessibility, energy, other"
                },
                {
                  "key": "search",
                  "value": "{{search}}",
                  "description": "Search in name (all languages)"
                },
                {
                  "key": "is_active",
                  "value": "{{is_active}}",
                  "description": "Filter by active status (default: true)"
                },
                {
                  "key": "sort",
                  "value": "{{sort}}",
                  "description": "Sort field: sort_order, -sort_order, name.en, -name.en, group, -group"
                },
                {
                  "key": "lang",
                  "value": "{{lang}}",
                  "description": "Language for localized response (en, fr, de, it)"
                }
              ]
            },
            "description": "Get all amenities with optional filtering, pagination, and search.\n\nBy default, only active amenities are returned."
          },
          "response": [
            {
              "name": "Success Response",
              "status": "OK",
              "code": 200,
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/public/amenities",
                  "host": ["{{base_url}}"],
                  "path": ["public", "amenities"]
                }
              },
              "body": "{\n  \"success\": true,\n  \"message\": \"Amenities retrieved successfully\",\n  \"data\": [\n    {\n      \"id\": \"507f1f77bcf86cd799439011\",\n      \"group\": \"parking\",\n      \"icon\": \"parking\",\n      \"name\": {\n        \"en\": \"Parking\",\n        \"fr\": \"Parking\",\n        \"de\": \"Parkplatz\",\n        \"it\": \"Parcheggio\"\n      },\n      \"sort_order\": 1,\n      \"is_active\": true,\n      \"created_at\": \"2024-01-15T10:00:00.000Z\",\n      \"updated_at\": \"2024-01-15T10:00:00.000Z\"\n    }\n  ],\n  \"meta\": {\n    \"total\": 41,\n    \"page\": 1,\n    \"limit\": 50,\n    \"totalPages\": 1,\n    \"hasNextPage\": false,\n    \"hasPrevPage\": false\n  }\n}"
            },
            {
              "name": "Localized Response (French)",
              "status": "OK",
              "code": 200,
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/public/amenities?lang=fr",
                  "host": ["{{base_url}}"],
                  "path": ["public", "amenities"],
                  "query": [{"key": "lang", "value": "fr"}]
                }
              },
              "body": "{\n  \"success\": true,\n  \"message\": \"Amenities retrieved successfully\",\n  \"data\": [\n    {\n      \"id\": \"507f1f77bcf86cd799439011\",\n      \"group\": \"parking\",\n      \"icon\": \"parking\",\n      \"name\": \"Parking\",\n      \"sort_order\": 1,\n      \"is_active\": true\n    }\n  ],\n  \"meta\": { ... }\n}"
            }
          ]
        },
        {
          "name": "Get Amenity by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept-Language",
                "value": "{{lang}}",
                "description": "Language preference (en, fr, de, it)"
              }
            ],
            "url": {
              "raw": "{{base_url}}/public/amenities/{{amenity_id}}?lang={{lang}}",
              "host": ["{{base_url}}"],
              "path": ["public", "amenities", "{{amenity_id}}"],
              "query": [
                {
                  "key": "lang",
                  "value": "{{lang}}",
                  "description": "Language for localized response (en, fr, de, it)"
                }
              ]
            },
            "description": "Get a single amenity by its ID.\n\nReturns amenity details with all translations or localized name if lang parameter is provided."
          },
          "response": [
            {
              "name": "Success Response",
              "status": "OK",
              "code": 200,
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/public/amenities/507f1f77bcf86cd799439011",
                  "host": ["{{base_url}}"],
                  "path": ["public", "amenities", "507f1f77bcf86cd799439011"]
                }
              },
              "body": "{\n  \"success\": true,\n  \"message\": \"Amenity retrieved successfully\",\n  \"data\": {\n    \"id\": \"507f1f77bcf86cd799439011\",\n    \"group\": \"parking\",\n    \"icon\": \"parking\",\n    \"name\": {\n      \"en\": \"Parking\",\n      \"fr\": \"Parking\",\n      \"de\": \"Parkplatz\",\n      \"it\": \"Parcheggio\"\n    },\n    \"sort_order\": 1,\n    \"is_active\": true,\n    \"created_at\": \"2024-01-15T10:00:00.000Z\",\n    \"updated_at\": \"2024-01-15T10:00:00.000Z\"\n  }\n}"
            },
            {
              "name": "Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"message\": \"Amenity not found\"\n}"
            }
          ]
        },
        {
          "name": "Get Amenities by Group",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept-Language",
                "value": "{{lang}}",
                "description": "Language preference (en, fr, de, it)"
              }
            ],
            "url": {
              "raw": "{{base_url}}/public/amenities/group/{{group}}?lang={{lang}}",
              "host": ["{{base_url}}"],
              "path": ["public", "amenities", "group", "{{group}}"],
              "query": [
                {
                  "key": "lang",
                  "value": "{{lang}}",
                  "description": "Language for localized response (en, fr, de, it)"
                }
              ]
            },
            "description": "Get all active amenities belonging to a specific group.\n\n**Valid groups:**\n- `general` - General amenities\n- `kitchen` - Kitchen-related\n- `bathroom` - Bathroom-related\n- `outdoor` - Outdoor features\n- `security` - Security features\n- `parking` - Parking options\n- `accessibility` - Accessibility features\n- `energy` - Energy efficiency\n- `other` - Other amenities"
          },
          "response": [
            {
              "name": "Success Response (Parking)",
              "status": "OK",
              "code": 200,
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/public/amenities/group/parking",
                  "host": ["{{base_url}}"],
                  "path": ["public", "amenities", "group", "parking"]
                }
              },
              "body": "{\n  \"success\": true,\n  \"message\": \"Amenities retrieved successfully\",\n  \"data\": [\n    {\n      \"id\": \"507f1f77bcf86cd799439011\",\n      \"group\": \"parking\",\n      \"icon\": \"parking\",\n      \"name\": {\n        \"en\": \"Parking\",\n        \"fr\": \"Parking\",\n        \"de\": \"Parkplatz\",\n        \"it\": \"Parcheggio\"\n      },\n      \"sort_order\": 1,\n      \"is_active\": true\n    },\n    {\n      \"id\": \"507f1f77bcf86cd799439012\",\n      \"group\": \"parking\",\n      \"icon\": \"garage\",\n      \"name\": {\n        \"en\": \"Garage\",\n        \"fr\": \"Garage\",\n        \"de\": \"Garage\",\n        \"it\": \"Garage\"\n      },\n      \"sort_order\": 2,\n      \"is_active\": true\n    }\n  ]\n}"
            },
            {
              "name": "Invalid Group",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"Validation failed\",\n  \"errors\": [\n    {\n      \"field\": \"group\",\n      \"message\": \"Group must be one of: general, kitchen, bathroom, outdoor, security, parking, accessibility, energy, other\"\n    }\n  ]\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Admin Endpoints",
      "description": "Admin endpoints for managing amenities (requires authentication and permissions)",
      "item": [
        {
          "name": "Get All Amenities (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "description": "JWT access token"
              },
              {
                "key": "Accept-Language",
                "value": "{{lang}}",
                "description": "Language preference (en, fr, de, it)"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/amenities?page={{page}}&limit={{limit}}&group={{group}}&search={{search}}&is_active={{is_active}}&sort={{sort}}&lang={{lang}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "amenities"],
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}",
                  "description": "Page number (default: 1)"
                },
                {
                  "key": "limit",
                  "value": "{{limit}}",
                  "description": "Items per page (default: 50, max: 100)"
                },
                {
                  "key": "group",
                  "value": "{{group}}",
                  "description": "Filter by group"
                },
                {
                  "key": "search",
                  "value": "{{search}}",
                  "description": "Search in name (all languages)"
                },
                {
                  "key": "is_active",
                  "value": "{{is_active}}",
                  "description": "Filter by active status"
                },
                {
                  "key": "sort",
                  "value": "{{sort}}",
                  "description": "Sort field"
                },
                {
                  "key": "lang",
                  "value": "{{lang}}",
                  "description": "Language for localized response"
                }
              ]
            },
            "description": "Get all amenities including inactive ones.\n\n**Required Permission:** `amenities:read`"
          },
          "response": [
            {
              "name": "Success Response",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Amenities retrieved successfully\",\n  \"data\": [...],\n  \"meta\": {...}\n}"
            },
            {
              "name": "Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"message\": \"Unauthorized - No token provided\"\n}"
            },
            {
              "name": "Forbidden",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"success\": false,\n  \"message\": \"Forbidden - Insufficient permissions\"\n}"
            }
          ]
        },
        {
          "name": "Create Amenity",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "description": "JWT access token"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": {\n    \"en\": \"Swimming Pool\",\n    \"fr\": \"Piscine\",\n    \"de\": \"Schwimmbad\",\n    \"it\": \"Piscina\"\n  },\n  \"group\": \"outdoor\",\n  \"icon\": \"pool\",\n  \"sort_order\": 10,\n  \"is_active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/amenities",
              "host": ["{{base_url}}"],
              "path": ["admin", "amenities"]
            },
            "description": "Create a new amenity.\n\n**Required Permission:** `amenities:create`\n\n**Request Body:**\n- `name` (required): Object with translations for en, fr, de, it (all required)\n- `group` (required): One of: general, kitchen, bathroom, outdoor, security, parking, accessibility, energy, other\n- `icon` (optional): Icon identifier string\n- `sort_order` (optional): Display order (default: 0)\n- `is_active` (optional): Active status (default: true)"
          },
          "response": [
            {
              "name": "Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"Amenity created successfully\",\n  \"data\": {\n    \"id\": \"507f1f77bcf86cd799439099\",\n    \"group\": \"outdoor\",\n    \"icon\": \"pool\",\n    \"name\": {\n      \"en\": \"Swimming Pool\",\n      \"fr\": \"Piscine\",\n      \"de\": \"Schwimmbad\",\n      \"it\": \"Piscina\"\n    },\n    \"sort_order\": 10,\n    \"is_active\": true,\n    \"created_at\": \"2024-01-15T10:00:00.000Z\",\n    \"updated_at\": \"2024-01-15T10:00:00.000Z\"\n  }\n}"
            },
            {
              "name": "Validation Error",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"Validation failed\",\n  \"errors\": [\n    {\n      \"field\": \"name.fr\",\n      \"message\": \"French name is required\"\n    },\n    {\n      \"field\": \"group\",\n      \"message\": \"Group is required\"\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Update Amenity",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "description": "JWT access token"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": {\n    \"en\": \"Updated Parking\",\n    \"fr\": \"Parking mis à jour\",\n    \"de\": \"Aktualisierter Parkplatz\",\n    \"it\": \"Parcheggio aggiornato\"\n  },\n  \"sort_order\": 5,\n  \"is_active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/amenities/{{amenity_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "amenities", "{{amenity_id}}"]
            },
            "description": "Update an existing amenity.\n\n**Required Permission:** `amenities:create`\n\n**Request Body (all fields optional):**\n- `name`: Object with translations (all 4 languages required if provided)\n- `group`: Amenity group\n- `icon`: Icon identifier\n- `sort_order`: Display order\n- `is_active`: Active status"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Amenity updated successfully\",\n  \"data\": {\n    \"id\": \"507f1f77bcf86cd799439011\",\n    \"group\": \"parking\",\n    \"icon\": \"parking\",\n    \"name\": {\n      \"en\": \"Updated Parking\",\n      \"fr\": \"Parking mis à jour\",\n      \"de\": \"Aktualisierter Parkplatz\",\n      \"it\": \"Parcheggio aggiornato\"\n    },\n    \"sort_order\": 5,\n    \"is_active\": true,\n    \"updated_at\": \"2024-01-15T11:00:00.000Z\"\n  }\n}"
            },
            {
              "name": "Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"message\": \"Amenity not found\"\n}"
            }
          ]
        },
        {
          "name": "Delete Amenity",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "description": "JWT access token"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/amenities/{{amenity_id}}",
              "host": ["{{base_url}}"],
              "path": ["admin", "amenities", "{{amenity_id}}"]
            },
            "description": "Delete an amenity.\n\n**Required Permission:** `amenities:delete`\n\n**Note:** This is a hard delete. Consider using the update endpoint to set `is_active: false` for soft delete."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Amenity deleted successfully\"\n}"
            },
            {
              "name": "Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"message\": \"Amenity not found\"\n}"
            }
          ]
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-refresh token if expired",
          "const tokenExpiry = pm.environment.get('token_expiry');",
          "if (tokenExpiry && Date.now() > parseInt(tokenExpiry)) {",
          "  pm.sendRequest({",
          "    url: pm.environment.get('base_url') + '/auth/refresh',",
          "    method: 'POST',",
          "    header: { 'Content-Type': 'application/json' },",
          "    body: { mode: 'raw', raw: JSON.stringify({ refresh_token: pm.environment.get('refresh_token') }) }",
          "  }, (err, res) => {",
          "    if (!err && res.json().success) {",
          "      pm.environment.set('auth_token', res.json().data.access_token);",
          "      pm.environment.set('token_expiry', Date.now() + 3600000);",
          "    }",
          "  });",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Common tests for all requests",
          "pm.test('Response time is acceptable', () => {",
          "  pm.expect(pm.response.responseTime).to.be.below(1000);",
          "});",
          "",
          "pm.test('Response has correct content type', () => {",
          "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
          "});",
          "",
          "// Save amenity_id from successful create/list responses",
          "if (pm.response.code === 200 || pm.response.code === 201) {",
          "  const jsonData = pm.response.json();",
          "  if (jsonData.data) {",
          "    if (jsonData.data.id) {",
          "      pm.environment.set('amenity_id', jsonData.data.id);",
          "    } else if (Array.isArray(jsonData.data) && jsonData.data.length > 0) {",
          "      pm.environment.set('amenity_id', jsonData.data[0].id);",
          "    }",
          "  }",
          "}"
        ]
      }
    }
  ],
