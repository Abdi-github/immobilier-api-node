{
  "info": {
    "_postman_id": "search-module-collection",
    "name": "Search Module",
    "description": "Comprehensive search functionality for the Immobilier.ch API including property search, location search, suggestions, and faceted search.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Public",
      "description": "Public search endpoints accessible without authentication",
      "item": [
        {
          "name": "Unified Search",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept-Language",
                "value": "{{lang}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/public/search?q=Geneva&lang={{lang}}&limit=5",
              "host": ["{{base_url}}"],
              "path": ["public", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "Geneva",
                  "description": "Search query"
                },
                {
                  "key": "lang",
                  "value": "{{lang}}",
                  "description": "Language code (en, fr, de, it)"
                },
                {
                  "key": "limit",
                  "value": "5",
                  "description": "Max results per category"
                }
              ]
            },
            "description": "Search properties and locations in a single request"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has success true', () => pm.expect(pm.response.json().success).to.be.true);",
                  "pm.test('Response has properties', () => pm.expect(pm.response.json().data.properties).to.exist);",
                  "pm.test('Response has locations', () => pm.expect(pm.response.json().data.locations).to.exist);",
                  "pm.test('Response time < 500ms', () => pm.expect(pm.response.responseTime).to.be.below(500));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
