      "name": "Admin",
      "description": "Admin search endpoints (requires authentication)",
      "item": [
        {
          "name": "Invalidate Search Cache",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pattern\": \"search:*\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/search/cache/invalidate",
              "host": ["{{base_url}}"],
              "path": ["admin", "search", "cache", "invalidate"]
            },
            "description": "Invalidate search cache (requires admin:manage permission)"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has success true', () => pm.expect(pm.response.json().success).to.be.true);",
                  "pm.test('Message contains invalidated', () => pm.expect(pm.response.json().message).to.include('invalidated'));"
                ],
                "type": "text/javascript"
              }
            }
