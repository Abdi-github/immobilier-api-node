# Environment Configuration
# Copy this file to .env and fill in the values

# ===========================================
# APPLICATION SETTINGS
# ===========================================
NODE_ENV=development
PORT=4003
API_VERSION=v1
API_PREFIX=/api

# ===========================================
# DATABASE - MongoDB
# ===========================================
MONGODB_URI=mongodb://mongodb:27017/immobilier_dev
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_DB_NAME=immobilier_dev

# ===========================================
# CACHE - Redis
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# JWT Authentication
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=immobilier.ch
JWT_AUDIENCE=immobilier.ch

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS_GUEST=100
RATE_LIMIT_MAX_REQUESTS_AUTH=300
RATE_LIMIT_MAX_REQUESTS_ADMIN=1000

# ===========================================
# CORS Settings
# ===========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:4003
CORS_CREDENTIALS=true

# ===========================================
# CLOUDINARY (Image Storage)
# ===========================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=immobilier

# ===========================================
# IMAGE UPLOAD SETTINGS
# ===========================================
# Maximum file size in bytes (default: 10MB)
MAX_IMAGE_SIZE=10485760
# Maximum number of images per upload batch
MAX_IMAGES_PER_BATCH=10
# Maximum images per property
MAX_IMAGES_PER_PROPERTY=50
# Allowed image types (comma-separated MIME types)
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
# Enable image optimization (resize, compress)
ENABLE_IMAGE_OPTIMIZATION=true
# Thumbnail dimensions
THUMBNAIL_WIDTH=300
THUMBNAIL_HEIGHT=200
# Maximum image width (will be resized if larger)
MAX_IMAGE_WIDTH=2000
# Image quality for JPEG/WebP (1-100)
IMAGE_QUALITY=85

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=debug
LOG_DIR=logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# ===========================================
# i18n Settings
# ===========================================
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,fr,de,it

# ===========================================
# DeepL Translation API (optional)
# ===========================================
DEEPL_API_KEY=

# ===========================================
# LibreTranslate (Self-Hosted Translation)
# ===========================================
# Free, unlimited, self-hosted translation service
# URL inside Docker network: http://libretranslate:5000
# URL from host machine: http://localhost:5050
LIBRETRANSLATE_URL=http://libretranslate:5000

# Translation Provider: 'deepl' | 'libretranslate' | 'auto'
# 'auto' will try DeepL first, fallback to LibreTranslate
TRANSLATION_PROVIDER=libretranslate

# ===========================================
# BCRYPT
# ===========================================
BCRYPT_SALT_ROUNDS=12

# ===========================================
# PAGINATION DEFAULTS
# ===========================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
# SMTP Settings
# For development, use Mailpit (included in Docker Compose)
# For production, use a real SMTP service (SendGrid, Mailgun, AWS SES, etc.)
MAIL_HOST=mailpit
MAIL_PORT=1026
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@immobilier.ch
MAIL_FROM_NAME=Immobilier.ch
MAIL_SECURE=false
MAIL_REPLY_TO=support@immobilier.ch

# Email Queue Configuration
# Concurrency: Number of emails processed simultaneously
EMAIL_QUEUE_CONCURRENCY=3
# Max retries: Number of retry attempts for failed emails
EMAIL_QUEUE_MAX_RETRIES=3

# ===========================================
# FRONTEND URLS (for email links)
# ===========================================
FRONTEND_URL=http://localhost:5174
FRONTEND_ADMIN_URL=http://localhost:5174
SUPPORT_EMAIL=support@immobilier.ch

# ===========================================
# PRODUCTION SMTP EXAMPLES
# ===========================================
# SendGrid:
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USER=apikey
# MAIL_PASSWORD=your-sendgrid-api-key
# MAIL_SECURE=false

# Mailgun:
# MAIL_HOST=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USER=postmaster@yourdomain.com
# MAIL_PASSWORD=your-mailgun-password
# MAIL_SECURE=false

# AWS SES:
# MAIL_HOST=email-smtp.us-east-1.amazonaws.com
# MAIL_PORT=587
# MAIL_USER=your-ses-access-key
# MAIL_PASSWORD=your-ses-secret-key
# MAIL_SECURE=false