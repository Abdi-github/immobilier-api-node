NODE_ENV=production
PORT=4003
API_VERSION=v1
API_PREFIX=/api

MONGODB_URI=mongodb://mongodb:27017/immobilier_prod
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_DB_NAME=immobilier_prod

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=immobilier.swiftapp.ch
JWT_AUDIENCE=immobilier.swiftapp.ch

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS_GUEST=100
RATE_LIMIT_MAX_REQUESTS_AUTH=300
RATE_LIMIT_MAX_REQUESTS_ADMIN=1000

CORS_ORIGIN=https://immobilier-react.swiftapp.ch,https://immobilier-vue.swiftapp.ch,https://immobilier-admin.swiftapp.ch
CORS_CREDENTIALS=true

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=immobilier_node

LOG_LEVEL=warn
LOG_DIR=logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,fr,de,it
DEEPL_API_KEY=

BCRYPT_SALT_ROUNDS=12
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@immobilier.swiftapp.ch
MAIL_FROM_NAME=Immobilier
MAIL_SECURE=false
MAIL_REPLY_TO=support@immobilier.swiftapp.ch
EMAIL_QUEUE_CONCURRENCY=3
EMAIL_QUEUE_MAX_RETRIES=3

FRONTEND_URL=https://immobilier-react.swiftapp.ch
FRONTEND_ADMIN_URL=https://immobilier-admin.swiftapp.ch
SUPPORT_EMAIL=support@immobilier.swiftapp.ch
